{
  "name": "Práctica 12 de PAI",
  "description": "Hangman Game",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "main": "index.js",
  "scripts": {
    "run": "nohup npm run dev:server > server.log 2>&1 &",
    "build:p12": "tsc",
    "docs": "typedoc",
    "tsc:watch": "tsc -w",
    "push": "rm *~; git pull; git add . ; git commit -m 'Code improvement'; git push",
    "pull": "git pull",
    "test": "jest",
    "lint:ci": "eslint \"src/**/*.ts\"",
    "dev:server": "node scripts/dev-server.js",
    "start": "npm run build && node dist/main.js",
    "build:vite": "npm run build:p12 && npm run build",
    "build": "vite build",
    "build:all": "npm run build:vite && npm run docs",
    "build:css": "sass --load-path=node_modules --silence-deprecation=if-function --no-source-map src/exercises/home-work/ull-bulma.scss public/ull-bulma.css",
    "sonar": "npx sonarqube-scanner"
  },
  "keywords": [
    "PAI"
  ],
  "author": "F. de Sande <fsande@ull.es>",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "mathjs": "^15.2.0",
    "vite": "^8.0.8"
  },
  "devDependencies": {
    "@exercism/babel-preset-typescript": "^0.1.0",
    "@exercism/eslint-config-typescript": "^0.4.1",
    "@types/express": "^4.17.17",
    "@types/node": "^20.19.0",
    "@typescript-eslint/eslint-plugin": "^5.50.0",
    "babel-jest": "^27.5.1",
    "bulma": "^1.0.4",
    "core-js": "^3.21.0",
    "eslint": "^8.33.0",
    "eslint-config-standard-with-typescript": "^34.0.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-n": "^15.6.1",
    "eslint-plugin-promise": "^6.1.1",
    "jest": "^29.4.3",
    "sass": "^1.80.0",
    "sonarqube-scanner": "^4.0.0",
    "ts-node": "^10.0.0",
    "tsc-watch": "^6.0.0",
    "typedoc": "^0.23.25",
    "typescript": "^5.0.4"
  }
}
